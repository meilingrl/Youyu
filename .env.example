# Copy this file to .env for local Compose-based staging exercises.
# Use generated secrets in the local .env file. Never commit real credentials.

DB_HOST=db
DB_PORT=13306
DB_NAME=youyu
DB_USERNAME=youyu
DB_PASSWORD=replace-with-generated-database-password
MYSQL_ROOT_PASSWORD=replace-with-generated-root-password
APP_JWT_SECRET=replace-with-generated-jwt-secret-at-least-32-characters
HTTP_PORT=18080
BACKEND_PORT=18081
YOUYU_CORS_ALLOWED_ORIGINS=http://localhost:18080,http://127.0.0.1:18080
YOUYU_CORS_ALLOWED_ORIGIN_PATTERNS=

# Optional Alipay sandbox verification. Leave disabled for the default mock flow.
ALIPAY_SANDBOX_ENABLED=false
ALIPAY_SANDBOX_APP_ID=
ALIPAY_SANDBOX_PRIVATE_KEY=
ALIPAY_SANDBOX_PUBLIC_KEY=
ALIPAY_SANDBOX_NOTIFY_URL=
ALIPAY_SANDBOX_GATEWAY_URL=https://openapi-sandbox.dl.alipaydev.com/gateway.do

# Optional Meilisearch product-search index. Leave disabled to use MySQL fallback.
MEILISEARCH_ENABLED=false
MEILISEARCH_HOST=http://localhost:7700
MEILISEARCH_API_KEY=
MEILISEARCH_PRODUCT_INDEX=youyu_products
MEILISEARCH_TIMEOUT=2s

# Optional Redis cache candidate for launch-performance rehearsal.
# Compose starts Redis, but backend cache usage and Redis health are disabled
# until these switches are explicitly enabled.
REDIS_PORT=16379
REDIS_PASSWORD=
REDIS_MAXMEMORY=256mb
REDIS_MAXMEMORY_POLICY=allkeys-lru
REDIS_TIMEOUT=2s
REDIS_POOL_MAX_ACTIVE=20
REDIS_POOL_MAX_IDLE=10
REDIS_POOL_MIN_IDLE=0
YOUYU_REDIS_CACHE_ENABLED=false
YOUYU_REDIS_HEALTH_ENABLED=false
YOUYU_REDIS_CACHE_KEY_PREFIX=youyu:cache:
YOUYU_REDIS_HOT_SEARCH_TTL=1h
YOUYU_REDIS_HOME_RECOMMEND_TTL=15m
YOUYU_REDIS_ALSO_BOUGHT_TTL=15m

# Optional logistics tracking and map-provider configuration.
# Amap WebService key is backend-only. Frontend Amap JS keys are public
# browser build-time values; restrict them by domain before any real deployment.
YOUYU_AMAP_ENABLED=false
YOUYU_AMAP_WEB_SERVICE_KEY=
YOUYU_LOGISTICS_TRACKING_ENABLED=false
YOUYU_LOGISTICS_TRACKING_PROVIDER=disabled
KDNIAO_BUSINESS_ID=
KDNIAO_APP_KEY=
KDNIAO_ENDPOINT=https://api.kdniao.com/Ebusiness/EbusinessOrderHandle.aspx
YOUYU_LOGISTICS_TRACKING_TIMEOUT_SECONDS=5

# Optional frontend map rendering build args forwarded by Compose.
VITE_AMAP_JS_KEY=
VITE_AMAP_SECURITY_CODE=

# Optional SMTP delivery. Required for public registration and password reset
# email delivery in a non-test public environment.
APP_MAIL_HOST=
APP_MAIL_PORT=465
APP_MAIL_USERNAME=
APP_MAIL_PASSWORD=
APP_MAIL_FROM=
APP_MAIL_SSL_ENABLED=true
